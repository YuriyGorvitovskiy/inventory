{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inventory.local/schemas/entity-definition.schema.json",
  "title": "Entity Definition Format v1",
  "type": "object",
  "required": ["format_version", "entity"],
  "properties": {
    "format_version": {
      "type": "integer",
      "enum": [1],
      "description": "Format version for compatibility checks."
    },
    "entity": {
      "$ref": "#/$defs/entity"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["name", "fields"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "table": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": {
          "type": "string"
        },
        "id_policy": {
          "type": "string",
          "enum": ["implicit_int64"],
          "default": "implicit_int64"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      },
      "additionalProperties": true
    },
    "field": {
      "type": "object",
      "required": ["name", "type", "default"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": ["boolean", "integer", "float", "timestamp", "string", "text", "reference"]
        },
        "destination_type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": {
          "type": "string"
        },
        "default": {
          "type": ["string", "number", "integer", "boolean"]
        },
        "indexed": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "not": {
            "properties": {
              "name": { "const": "id" }
            },
            "required": ["name"]
          }
        },
        {
          "not": {
            "required": ["primary_key"]
          }
        },
        {
          "not": {
            "required": ["generated"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "reference" }
            }
          },
          "then": {
            "required": ["destination_type"],
            "properties": {
              "default": {
                "anyOf": [
                  {
                    "type": "integer",
                    "minimum": 0
                  },
                  {
                    "type": "string",
                    "const": "none"
                  }
                ]
              }
            }
          },
          "else": {
            "not": {
              "required": ["destination_type"]
            }
          }
        }
      ],
      "additionalProperties": true
    }
  }
}
